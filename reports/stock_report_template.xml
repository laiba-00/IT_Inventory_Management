<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Stock Level Report Template -->
    <template id="report_it_stock_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>IT Equipment Stock Report</h2>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Device Type</th>
                                <th>Location</th>
                                <th>Warranty Expiry</th>
                                <th>Min Qty</th>
                                <th>On Hand Qty</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="product">
                                <tr>
                                    <td><t t-esc="product.name"/></td>
                                    <td><t t-esc="product.it_device_type or '-'"/></td>
                                    <td><t t-esc="product.it_device_location or '-'"/></td>
                                    <td><t t-esc="product.it_warranty_date or '-'"/></td>
                                    <td><t t-esc="product.it_min_qty"/></td>
                                    <td><t t-esc="product.qty_available"/></td>
                                    <td>
                                        <span t-if="product.it_low_stock_alert"
                                              style="color:red;font-weight:bold;">
                                            LOW STOCK
                                        </span>
                                        <span t-else="" style="color:green;">OK</span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!-- Stock Movement History Report Template -->
    <template id="report_it_movement_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>IT Equipment Stock Movement History</h2>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Product</th>
                                <th>From</th>
                                <th>To</th>
                                <th>Quantity</th>
                                <th>Reference</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="move">
                                <tr>
                                    <td><t t-esc="move.date"/></td>
                                    <td><t t-esc="move.product_id.name"/></td>
                                    <td><t t-esc="move.location_id.name"/></td>
                                    <td><t t-esc="move.location_dest_id.name"/></td>
                                    <td><t t-esc="move.quantity"/></td>
                                    <td><t t-esc="move.reference"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>