<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- IT Stock Level Report — PDF -->
    <record id="action_it_stock_report" model="ir.actions.report">
        <field name="name">IT Stock Report</field>
        <field name="model">product.template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_inventory.report_it_stock_template</field>
        <field name="report_file">it_inventory.report_it_stock_template</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_type">report</field>
    </record>

    <!-- IT Stock Movement History Report — PDF -->
    <record id="action_it_movement_report" model="ir.actions.report">
        <field name="name">IT Stock Movement History</field>
        <field name="model">stock.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_inventory.report_it_movement_template</field>
        <field name="report_file">it_inventory.report_it_movement_template</field>
        <field name="binding_model_id" ref="stock.model_stock_move"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Stock Level Report — Menu action -->
    <record id="action_it_stock_report_menu" model="ir.actions.act_window">
        <field name="name">IT Stock Level Report</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="it_inventory.view_it_stock_report_tree"/>
        <field name="domain">[('it_device_type', '!=', False)]</field>
    </record>

    <!-- Movement History — Menu action -->
    <record id="action_it_movement_report_menu" model="ir.actions.act_window">
        <field name="name">Stock Movement History</field>
        <field name="res_model">stock.move</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_stock_move_it_tree"/>
        <field name="domain">[('product_id.it_device_type', '!=', False), ('state', '=', 'done')]</field>
    </record>
</odoo>