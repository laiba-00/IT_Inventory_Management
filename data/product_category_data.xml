<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="product_category_it" model="product.category">
            <field name="name">IT Equipment</field>
        </record>

        <record id="product_cctv" model="product.template">
            <field name="name">CCTV Camera</field>
            <field name="type">product</field>
            <field name="categ_id" ref="product_category_it"/>
            <field name="it_device_type">cctv</field>
        </record>

        <record id="product_access_point" model="product.template">
            <field name="name">Access Point</field>
            <field name="type">product</field>
            <field name="categ_id" ref="product_category_it"/>
            <field name="it_device_type">access_point</field>
        </record>

        <record id="product_network_switch" model="product.template">
            <field name="name">Network Switch</field>
            <field name="type">product</field>
            <field name="categ_id" ref="product_category_it"/>
            <field name="it_device_type">network_switch</field>
        </record>

        <record id="product_router" model="product.template">
            <field name="name">Router</field>
            <field name="type">product</field>
            <field name="categ_id" ref="product_category_it"/>
            <field name="it_device_type">router</field>
        </record>
    </data>
</odoo>